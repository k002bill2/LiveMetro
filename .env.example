# External APIs (Seoul Subway - Real-time Arrival)
# 서울 열린데이터광장에서 발급받은 API 키 (최대 3개)
EXPO_PUBLIC_SEOUL_SUBWAY_API_KEY=your_seoul_subway_api_key
EXPO_PUBLIC_SEOUL_SUBWAY_API_KEY_2=your_seoul_subway_api_key_2
EXPO_PUBLIC_SEOUL_SUBWAY_API_KEY_3=your_seoul_subway_api_key_3
SEOUL_SUBWAY_API_BASE_URL=http://swopenapi.seoul.go.kr/api/subway


# 서울 열린데이터광장 - 데이터 포털 API (시간표/역정보 등 정적 데이터)
# 실시간 지하철 키와 별도로 발급 필요 (일반 인증키)
EXPO_PUBLIC_DATA_PORTAL_API_KEY=your_data_portal_api_key
EXPO_PUBLIC_DATA_PORTAL_API_KEY_2=your_data_portal_api_key_2


# App Configuration
APP_ENV=development
API_TIMEOUT=10000
NOTIFICATION_DELAY_THRESHOLD=5
CACHE_DURATION_MINUTES=30

# Analytics (optional)
ANALYTICS_TRACKING_ID=your_analytics_id

# Feature Flags
ENABLE_CONGESTION_DATA=true
ENABLE_ML_PREDICTIONS=false
ENABLE_PREMIUM_FEATURES=true
ENABLE_DEBUG_LOGGING=true

