{
  "error-handling": {
    "type": "guideline",
    "enforcement": "require",
    "priority": "high",
    "description": "에러 처리 패턴 (React Native: ErrorBoundary, Firebase: try/catch)",
    "promptTriggers": {
      "keywords": ["error", "catch", "try", "에러", "오류"],
      "intentPatterns": ["(handle|catch).*?(error|exception)"]
    },
    "fileTriggers": {
      "pathPatterns": ["**/services/**", "**/hooks/**"]
    },
    "reminder": "에러는 빈 배열/null 반환, throw 지양"
  },
  "test-automation": {
    "type": "skill",
    "enforcement": "require",
    "priority": "high",
    "description": "Jest + React Native Testing Library 테스트 생성",
    "promptTriggers": {
      "keywords": ["test", "jest", "coverage", "tdd", "testing library"],
      "intentPatterns": ["(write|add|create).*?test"]
    },
    "fileTriggers": {
      "pathPatterns": ["**/__tests__/**", "**/*.test.ts", "**/*.test.tsx"]
    }
  },
  "react-native-development": {
    "type": "skill",
    "enforcement": "require",
    "priority": "high",
    "description": "React Native + Expo 컴포넌트 개발",
    "promptTriggers": {
      "keywords": ["react native", "component", "screen", "expo", "컴포넌트", "화면"],
      "intentPatterns": ["(create|add|make).*?(component|screen)", "(react native|RN).*?(개발|구현)"]
    },
    "fileTriggers": {
      "pathPatterns": ["src/**/*.tsx", "src/**/*.ts"]
    }
  },
  "firebase-integration": {
    "type": "domain",
    "enforcement": "require",
    "priority": "high",
    "description": "Firebase Auth + Firestore 통합",
    "promptTriggers": {
      "keywords": ["firebase", "firestore", "auth", "collection", "document"],
      "intentPatterns": ["(firebase|firestore).*?(auth|query|collection)"]
    },
    "fileTriggers": {
      "pathPatterns": ["src/services/firebase*.ts", "src/config/firebase*.ts"]
    }
  },
  "seoul-api-patterns": {
    "type": "domain",
    "enforcement": "require",
    "priority": "high",
    "description": "Seoul Open Data API 통합 (30초 폴링 제한)",
    "promptTriggers": {
      "keywords": ["seoul", "metro", "subway", "api", "실시간", "지하철"],
      "intentPatterns": ["(seoul|metro|subway).*?(api|data)"]
    },
    "fileTriggers": {
      "pathPatterns": ["src/services/train*.ts", "src/services/seoul*.ts"]
    },
    "reminder": "30초 최소 폴링 간격 준수"
  },
  "navigation-patterns": {
    "type": "guideline",
    "enforcement": "require",
    "priority": "high",
    "description": "React Navigation 6.x 패턴",
    "promptTriggers": {
      "keywords": ["navigation", "screen", "route", "navigate", "네비게이션"],
      "intentPatterns": ["(navigate|screen|route).*?(add|create)"]
    },
    "fileTriggers": {
      "pathPatterns": ["src/navigation/**"]
    }
  },
  "parallel-coordinator": {
    "type": "workflow",
    "enforcement": "suggest",
    "priority": "high",
    "description": "Coordinate parallel agent execution.",
    "promptTriggers": {
      "keywords": ["parallel", "concurrent", "multi-agent"],
      "intentPatterns": ["(parallel|concurrent).*?(agent|task)"]
    }
  },
  "verification-loop": {
    "type": "workflow",
    "enforcement": "suggest",
    "priority": "high",
    "description": "Boris Cherny style verification feedback loop.",
    "promptTriggers": {
      "keywords": ["verify", "verification", "check", "validate"],
      "intentPatterns": ["(verify|validate).*?(code|app)"]
    }
  },
  "dev-docs-workflow": {
    "type": "workflow",
    "enforcement": "suggest",
    "priority": "high",
    "description": "Dev Docs 3-파일 시스템 워크플로우",
    "promptTriggers": {
      "keywords": ["dev docs", "plan", "대규모 작업"],
      "intentPatterns": ["(create|make).*?(dev docs|plan)"]
    }
  },
  "cc-feature-implementer-main": {
    "type": "workflow",
    "enforcement": "suggest",
    "priority": "high",
    "description": "Phase-based feature plans with quality gates.",
    "promptTriggers": {
      "keywords": ["plan", "planning", "phases", "roadmap"],
      "intentPatterns": ["(create|make).*?plan"]
    }
  }
}
