{
  "error-handling": {
    "type": "guideline",
    "enforcement": "require",
    "priority": "high",
    "description": "에러 처리 패턴 (React Native: ErrorBoundary, Firebase: try/catch)",
    "promptTriggers": {
      "keywords": ["error", "catch", "try", "에러", "오류"],
      "intentPatterns": ["(handle|catch).*?(error|exception)"]
    },
    "fileTriggers": {
      "pathPatterns": ["**/services/**", "**/hooks/**"]
    },
    "reminder": "에러는 빈 배열/null 반환, throw 지양"
  },
  "test-automation": {
    "type": "skill",
    "enforcement": "require",
    "priority": "high",
    "description": "Jest + React Native Testing Library 테스트 생성",
    "agentFile": ".claude/agents/test-automation-specialist.md",
    "skillFile": ".claude/skills/test-automation/SKILL.md",
    "promptTriggers": {
      "keywords": ["test", "jest", "coverage", "tdd", "testing library", "테스트", "커버리지"],
      "intentPatterns": ["(write|add|create).*?test", "(run|check).*?coverage"]
    },
    "fileTriggers": {
      "pathPatterns": ["**/__tests__/**", "**/*.test.ts", "**/*.test.tsx"]
    }
  },
  "react-native-development": {
    "type": "skill",
    "enforcement": "require",
    "priority": "high",
    "description": "React Native + Expo 컴포넌트 개발",
    "agentFile": ".claude/agents/mobile-ui-specialist.md",
    "skillFile": ".claude/skills/react-native-development/SKILL.md",
    "promptTriggers": {
      "keywords": ["react native", "component", "screen", "expo", "컴포넌트", "화면", "ui"],
      "intentPatterns": ["(create|add|make).*?(component|screen)", "(react native|RN).*?(개발|구현)"]
    },
    "fileTriggers": {
      "pathPatterns": ["src/components/**/*.tsx", "src/screens/**/*.tsx"]
    }
  },
  "firebase-integration": {
    "type": "skill",
    "enforcement": "require",
    "priority": "high",
    "description": "Firebase Auth + Firestore 통합",
    "agentFile": ".claude/agents/mobile-ui-specialist.md",
    "skillFile": ".claude/skills/firebase-integration/SKILL.md",
    "promptTriggers": {
      "keywords": ["firebase", "firestore", "auth", "collection", "document", "인증", "로그인"],
      "intentPatterns": ["(firebase|firestore).*?(auth|query|collection)"]
    },
    "fileTriggers": {
      "pathPatterns": ["src/services/firebase*.ts", "src/config/firebase*.ts", "src/services/auth/**"]
    }
  },
  "seoul-api-patterns": {
    "type": "skill",
    "enforcement": "require",
    "priority": "high",
    "description": "Seoul Open Data API 통합 (30초 폴링 제한)",
    "skillFile": ".claude/skills/api-integration/SKILL.md",
    "promptTriggers": {
      "keywords": ["seoul", "metro", "subway", "api", "실시간", "지하철", "도착"],
      "intentPatterns": ["(seoul|metro|subway).*?(api|data)", "실시간.*?도착"]
