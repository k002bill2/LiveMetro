        "react native",
        "component",
        "screen",
        "expo",
        "컴포넌트",
        "화면",
        "ui"
      ],
      "intentPatterns": [
        "(create|add|make).*?(component|screen)",
        "(react native|RN).*?(개발|구현)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": [
        "src/components/**/*.tsx",
        "src/screens/**/*.tsx"
      ]
