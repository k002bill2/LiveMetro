  "quality-validation": {
    "type": "workflow",
    "enforcement": "require",
    "priority": "critical",
    "description": "최종 품질 검증 (구현 완료 후 자동 호출)",
    "agentFile": ".claude/agents/quality-validator.md",
    "promptTriggers": {
      "keywords": [
        "quality-validator",
        "quality validation",
        "품질 검증"
      ],
      "intentPatterns": [
        "(최종|final)\\s*(검증|validation)",
        "(구현|implement).*?(완료|done|finish).*(검증|validate)"
      ]
    }
  },
  "verification-loop": {
    "type": "workflow",
    "enforcement": "suggest",
    "priority": "normal",
    "description": "Boris Cherny 검증 피드백 루프",
    "skillFile": ".claude/skills/verification-loop/SKILL.md",
    "promptTriggers": {
      "keywords": [
        "verify-app",
        "verification loop",
        "피드백 루프"
      ],
      "intentPatterns": [
        "\\b(verify|validate)\\s+(the\\s+)?(app|build|code)\\b",
        "(타입체크|typecheck|tsc).*?(테스트|test)"
      ]
    }
  },
