{
  "error-handling": {
    "type": "guideline",
    "enforcement": "require",
    "priority": "high",
    "description": "에러 처리 패턴 (React Native: ErrorBoundary, Firebase: try/catch)",
    "promptTriggers": {
      "keywords": [
        "error",
        "catch",
        "try",
        "에러",
        "오류"
      ],
      "intentPatterns": [
        "(handle|catch).*?(error|exception)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": [
        "**/services/**",
        "**/hooks/**"
      ]
    },
    "reminder": "에러는 빈 배열/null 반환, throw 지양"
  },
  "test-automation": {
    "type": "skill",
    "enforcement": "require",
    "priority": "high",
    "description": "Jest + React Native Testing Library 테스트 생성",
    "agentFile": ".claude/agents/test-automation-specialist.md",
    "skillFile": ".claude/skills/test-automation/SKILL.md",
    "promptTriggers": {
      "keywords": [
        "test",
        "jest",
        "coverage",
        "tdd",
        "testing library",
        "테스트",
        "커버리지"
      ],
      "intentPatterns": [
        "(write|add|create).*?test",
        "(run|check).*?coverage"
      ]
    },
    "fileTriggers": {
      "pathPatterns": [
        "**/__tests__/**",
        "**/*.test.ts",
        "**/*.test.tsx"
      ]
    }
  },
  "react-native-development": {
