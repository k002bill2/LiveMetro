  "error-handling": {
    "type": "guideline",
    "enforcement": "require",
    "priority": "high",
    "description": "에러 처리 패턴 (React Native: ErrorBoundary, Firebase: try/catch)",
    "promptTriggers": {
      "keywords": [
        "error",
        "catch",
        "try",
        "에러",
        "오류"
      ],
      "intentPatterns": [
        "(handle|catch).*?(error|exception)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": [
        "**/services/**",
        "**/hooks/**"
      ]
    },
    "reminder": "에러는 빈 배열/null 반환, throw 지양"
  },
