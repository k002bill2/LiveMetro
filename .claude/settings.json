{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -c \"import json,sys; p=json.load(sys.stdin).get('tool_input',{}).get('file_path',''); blocked=['.env','secrets','.git/','google-services.json','eas.json','firestore.rules']; sys.exit(2 if any(b in p for b in blocked) else 0)\"",
            "timeout": 5,
            "statusMessage": "Path protection..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/ethicalValidator.js 2>/dev/null || true",
            "timeout": 5,
            "statusMessage": "Ethical validation..."
          }
        ]
      },
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/parallelCoordinator.js pre",
            "timeout": 5,
            "statusMessage": "Parallel coordination..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/geminiAutoTrigger.js 2>/dev/null || true",
            "timeout": 5,
            "statusMessage": "Gemini review queued..."
          },
          {
            "type": "command",
            "command": "node .claude/hooks/aceMatrixSync.js 2>/dev/null || true",
            "timeout": 3,
            "statusMessage": "ACE matrix sync..."
          }
        ]
      },
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/agentTracer.js 2>/dev/null || true",
            "timeout": 5,
            "statusMessage": "Agent tracing..."
          },
          {
            "type": "command",
            "command": "node .claude/hooks/parallelCoordinator.js post",
            "timeout": 5,
            "statusMessage": "Parallel cleanup..."
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.message' | xargs -I{} osascript -e 'display notification \"{}\" with title \"Claude Code\"'",
            "timeout": 5,
            "statusMessage": "Notifying..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/userPromptSubmit.js 2>/dev/null || true",
            "timeout": 5,
            "statusMessage": "Context activation..."
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{}' > .claude/coordination/active-locks.json && echo '{\"activeAgents\":[],\"completedAgents\":[],\"lastUpdated\":null,\"sessionId\":null}' > .claude/coordination/parallel-state.json",
            "timeout": 5,
            "statusMessage": "Session cleanup..."
          }
        ]
      }
    ]
  }
}
