{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/pathProtection.js",
            "timeout": 5,
            "statusMessage": "Path protection..."
          },
          {
            "type": "command",
            "command": "node .claude/hooks/fileLock.js acquire",
            "timeout": 5,
            "statusMessage": "File lock acquire..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/ethicalValidator.js",
            "timeout": 5,
            "statusMessage": "보안 명령 검사..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/fileLock.js release 2>/dev/null || true",
            "timeout": 5,
            "statusMessage": "File lock release..."
          },
          {
            "type": "command",
            "command": "node .claude/hooks/geminiAutoTrigger.js 2>/dev/null || true",
            "timeout": 5,
            "statusMessage": "Gemini review queued..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/outputSecretFilter.js 2>/dev/null || true",
            "timeout": 5,
            "statusMessage": "Secret filtering..."
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.message' | xargs -I{} osascript -e 'display notification \"{}\" with title \"Claude Code\"'",
            "timeout": 5,
            "statusMessage": "Notifying..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/userPromptSubmit.js 2>/dev/null || true",
            "timeout": 5,
            "statusMessage": "Context activation..."
          }
        ]
      }
    ]
  }
}
