# EditorConfig - https://editorconfig.org
# Top-most config file
root = true

# Default rules for all files
[*]
end_of_line = lf
charset = utf-8
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Markdown preserves trailing whitespace (two spaces = line break)
[*.md]
trim_trailing_whitespace = false

# Dotenv files: dotenv parsers are strict about leading indent and trailing whitespace.
# See 2026-04-26 incident in memory/feedback_secret_in_path_diagnostics.md
[.env*]
trim_trailing_whitespace = true
indent_style = unset
indent_size = unset

# TypeScript/JavaScript follow project ESLint config
[*.{ts,tsx,js,jsx}]
indent_size = 2

# JSON/YAML configs use 2-space indent
[*.{json,yml,yaml}]
indent_size = 2
